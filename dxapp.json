{
  "name": "eggd_cgp-qc-flags",
  "title": "eggd_cgp-qc-flags",
  "summary": "Post-process PURPLE output to emit structured QC flags and best-fit purity for NO_TUMOR samples",
  "version": "1.0.0",
  "dxapi": "1.0.0",
  "developers": ["org-emee_1"],
  "authorizedUsers": ["org-emee_1"],
  "inputSpec": [
    {"name": "sample_id",        "class": "string", "label": "Sample ID"},
    {"name": "purity_tsv",       "class": "file",   "label": "*.purple.purity.tsv from eggd_cgp-purple"},
    {"name": "purity_range_tsv", "class": "file",   "label": "*.purple.purity.range.tsv from eggd_cgp-purple"},
    {"name": "sigs_allocation",  "class": "file",   "label": "*.sig.allocation.tsv from cgp-sigs", "optional": true},
    {"name": "cup_summary",      "class": "file",   "label": "*.cuppa.pred_summ.tsv from cgp-cuppa", "optional": true}
  ],
  "outputSpec": [
    {"name": "qc_report", "class": "file", "label": "*.qc_report.tsv — structured QC summary with flags"}
  ],
  "runSpec": {
    "interpreter": "bash",
    "file": "src/code.sh",
    "distribution": "Ubuntu",
    "release": "24.04",
    "version": "0",
    "timeoutPolicy": {"*": {"hours": 1}},
    "systemRequirements": {
      "*": {"instanceType": "mem1_ssd1_v2_x2"}
    }
  },
  "regionalOptions": {"aws:eu-central-1": {}}
}
